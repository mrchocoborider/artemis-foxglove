{
  "name": "artemis-foxglove",
  "displayName": "Artemis II — Photo Stepper",
  "description": "Step through Artemis II photos one-by-one (or in slideshow mode), driving the player timeline via seekPlayback.",
  "publisher": "foxglove-internal",
  "homepage": "https://artemistimeline.com/",
  "version": "0.1.0",
  "license": "MIT",
  "main": "./dist/extension.js",
  "keywords": [
    "foxglove",
    "extension",
    "artemis",
    "nasa"
  ],
  "scripts": {
    "build": "foxglove-extension build",
    "foxglove:prepublish": "foxglove-extension build --mode production",
    "lint": "eslint .",
    "lint:ci": "eslint .",
    "lint:fix": "eslint --fix .",
    "local-install": "foxglove-extension install",
    "package": "foxglove-extension package",
    "pretest": "foxglove-extension pretest"
  },
  "devDependencies": {
    "@foxglove/eslint-plugin": "2.1.2",
    "@foxglove/extension": "2.52.0",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "create-foxglove-extension": "1.3.2",
    "eslint": "9.39.4",
    "prettier": "3.8.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "typescript": "5.9.3"
  }
}
